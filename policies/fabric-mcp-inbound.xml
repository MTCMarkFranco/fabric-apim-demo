<policies>
    <inbound>
        <base />

        <!-- Validate the incoming Bearer token -->
        <validate-azure-ad-token tenant-id="d7d6e19e-5176-4dea-a576-1681f77e0243"
                                  header-name="Authorization"
                                  failed-validation-httpcode="401"
                                  failed-validation-error-message="Unauthorized. Access token is missing, invalid, or expired."
                                  output-token-variable-name="validated-jwt">
            <audiences>
                <audience>https://api.fabric.microsoft.com</audience>
            </audiences>
        </validate-azure-ad-token>

        <!-- Extract UPN from the validated JWT -->
        <set-variable name="caller-upn" value="@{&#xA;            var jwt = (Jwt)context.Variables[&quot;validated-jwt&quot;];&#xA;            return jwt.Claims.GetValueOrDefault(&quot;upn&quot;, &quot;unknown&quot;);&#xA;        }" />

        <!-- Route to Fabric Data Agent MCP backend -->
        <set-backend-service base-url="https://api.fabric.microsoft.com/v1/mcp/workspaces/68dff95b-eeae-4b90-a563-557bcd9bde7f/dataagents/9696eb20-a285-4406-b72d-1a6d59e01142/agent" />

        <!-- Strip the /fabric-mcp/ operation path so the backend receives the root path -->
        <rewrite-uri template="/" />

        <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
        </set-header>

        <!-- Surface UPN in a header so API Diagnostics captures it in gateway logs -->
        <set-header name="X-Caller-UPN" exists-action="override">
            <value>@((string)context.Variables["caller-upn"])</value>
        </set-header>

        <!-- Emit custom metric for request tracking -->
        <emit-metric name="fabric-mcp-request" value="1" namespace="Fabric MCP Agent">
            <dimension name="Caller UPN" value="@((string)context.Variables[&quot;caller-upn&quot;])" />
        </emit-metric>
    </inbound>

    <backend>
        <!-- MCP Streamable HTTP returns SSE; disable APIM response buffering so
             chunks stream back to the client instead of waiting for completion.
             Long timeout supports long-running tool calls / streamed responses. -->
        <forward-request buffer-response="false" timeout="300" />
    </backend>

    <outbound>
        <base />

        <!-- Emit response metric -->
        <emit-metric name="fabric-mcp-response" value="1" namespace="Fabric MCP Agent">
            <dimension name="Caller UPN" value="@((string)context.Variables[&quot;caller-upn&quot;])" />
            <dimension name="Status Code" value="@(context.Response.StatusCode.ToString())" />
        </emit-metric>
    </outbound>

    <on-error>
        <base />

        <!-- MCP spec / RFC 9728: 401 must include WWW-Authenticate pointing to
             the protected-resource metadata so clients can discover OAuth flow. -->
        <choose>
            <when condition="@(context.Response != null &amp;&amp; context.Response.StatusCode == 401)">
                <set-header name="WWW-Authenticate" exists-action="override">
                    <value>Bearer realm="fabric-mcp", resource_metadata="https://pcc-apim.azure-api.net/.well-known/oauth-protected-resource"</value>
                </set-header>
            </when>
        </choose>

        <!-- Emit error metric -->
        <emit-metric name="fabric-mcp-error" value="1" namespace="Fabric MCP Agent">
            <dimension name="Caller UPN" value="@(context.Variables.ContainsKey(&quot;caller-upn&quot;) ? (string)context.Variables[&quot;caller-upn&quot;] : &quot;unknown&quot;)" />
            <dimension name="Error Reason" value="@(context.LastError.Reason)" />
        </emit-metric>
    </on-error>
</policies>
